{
  "name": "agent-test-manager",
  "version": "0.1.0",
  "description": "Desktop app for testing AI agents — no Python, no setup",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "lint": "node --check main.js preload.js src/server.js src/store.js src/workspace.js src/helpers.js",
    "lint:routes": "node --check src/routes/*.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "portfinder": "^1.0.32",
    "simple-git": "^3.27.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.continuia.agent-test-manager",
    "productName": "Agent Test Manager",
    "copyright": "Copyright 2026 Continuia",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "static/**/*",
      "node_modules/**/*",
      "!node_modules/@xenova/transformers/dist/ort-wasm*",
      "!**/__pycache__/**",
      "!**/*.py",
      "!server.py",
      "!workspaces/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agent Test Manager"
    },
    "extraResources": [],
    "asarUnpack": [
      "node_modules/@xenova/transformers/**"
    ]
  }
}
