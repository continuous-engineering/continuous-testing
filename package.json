{
  "name": "agent-test-manager",
  "version": "0.1.0",
  "description": "Desktop app for testing AI agents — no Python, no setup",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "lint": "node --check main.js preload.js src/server.js src/store.js src/workspace.js src/helpers.js src/executor.js src/scorer.js",
    "lint:routes": "node --check src/routes/*.js",
    "lint:all": "npm run lint && npm run lint:routes"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "portfinder": "^1.0.32",
    "simple-git": "^3.27.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.continuia.agent-test-manager",
    "productName": "Agent Test Manager",
    "copyright": "Copyright 2026 Continuia",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": {
      "provider": "generic",
      "url": "https://releases.continuia.com/agent-test-manager/"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "static/**/*",
      "node_modules/**/*",
      "!node_modules/@xenova/transformers/dist/ort-wasm*",
      "!**/__pycache__/**",
      "!**/*.py",
      "!server.py",
      "!workspaces/**",
      "!docs/**",
      "!.claude/**"
    ],
    "extraResources": [
      {
        "from": "workspaces",
        "to": "app/workspaces",
        "filter": [
          "**/*",
          "!**/results/**",
          "!**/logs/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agent Test Manager",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "asarUnpack": [
      "node_modules/@xenova/transformers/**"
    ]
  }
}
