{
  "name": "continuous-testing",
  "version": "0.1.0",
  "description": "Continuous.Testing — AI agent test manager by continuous.engineering",
  "author": {
    "name": "Shree Mandadi",
    "email": "shree@continuous.engineering",
    "url": "https://continuous.engineering"
  },
  "homepage": "https://continuous.engineering",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "lint": "node --check main.js preload.js src/server.js src/store.js src/workspace.js src/helpers.js src/executor.js src/scorer.js",
    "lint:routes": "node --check src/routes/*.js",
    "lint:all": "npm run lint && npm run lint:routes"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "portfinder": "^1.0.32",
    "simple-git": "^3.27.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.continuous.engineering.testing",
    "productName": "Continuous.Testing",
    "copyright": "Copyright 2026 Shree Mandadi — continuous.engineering",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": {
      "provider": "generic",
      "url": "https://releases.continuous.engineering/agent-test-manager/"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "static/**/*",
      "node_modules/**/*",
      "!node_modules/@xenova/transformers/dist/ort-wasm*",
      "!node_modules/sharp/**",
      "!node_modules/**/{test,tests,__tests__,spec,specs,example,examples,benchmark,benchmarks}/**",
      "!node_modules/**/*.{map,md,ts,flow}",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!workspaces/**",
      "!docs/**",
      "!build/**",
      "!dist/**",
      "!.claude/**"
    ],
    "compression": "maximum",
    "extraResources": [
      {
        "from": "workspaces",
        "to": "app/workspaces",
        "filter": [
          "**/*",
          "!**/results/**",
          "!**/logs/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/@xenova/transformers/**"
    ]
  }
}
